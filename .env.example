# GoalsTracker — Environment Variables
# Copy to .env and fill in production values:  cp .env.example .env

# SQL Server SA password (strong, required)
SA_PASSWORD=YourStrong!Passw0rd

# JWT signing secret (min 32 chars, keep secret)
JWT_SECRET=ChangeThisToALongRandomStringAtLeast32Characters!

# Your domain (used for CORS)
DOMAIN=localhost
